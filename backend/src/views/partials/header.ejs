<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lush Nails Spa - Panel Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: #f0ebe3;
      color: #2F4A34;
      min-height: 100vh;
    }
    a { text-decoration: none; color: inherit; }
    .sidebar {
      position: fixed; top: 0; left: 0; bottom: 0; width: 240px;
      background: #2F4A34; color: white; padding: 0;
      display: flex; flex-direction: column;
    }
    .sidebar h2 {
      padding: 24px 20px; font-size: 1.1rem; font-weight: 600;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      letter-spacing: 1px;
    }
    .sidebar nav { flex: 1; padding: 12px 0; }
    .sidebar a {
      display: block; padding: 12px 20px; font-size: 0.9rem;
      transition: all 0.2s; border-left: 3px solid transparent;
    }
    .sidebar a:hover, .sidebar a.active {
      background: rgba(255,255,255,0.1);
      border-left-color: #A7B8A0;
    }
    .sidebar a.active { background: rgba(255,255,255,0.15); font-weight: 600; }
    .sidebar .user-info {
      padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.1);
      font-size: 0.8rem; opacity: 0.8;
    }
    .sidebar .user-info a {
      display: inline; padding: 0; font-size: 0.8rem; text-decoration: underline;
    }
    .main {
      margin-left: 240px; padding: 30px 40px;
    }
    .top-bar {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 30px;
    }
    .top-bar h1 { font-size: 1.6rem; font-weight: 600; }
    table {
      width: 100%; border-collapse: collapse; background: white;
      border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    th, td { padding: 12px 16px; text-align: left; font-size: 0.85rem; }
    th { background: #2F4A34; color: white; font-weight: 600; }
    tr:not(:last-child) td { border-bottom: 1px solid #f0ebe3; }
    tr:hover td { background: #f8f5f0; }
    .btn {
      display: inline-block; padding: 8px 16px; border: none; border-radius: 6px;
      cursor: pointer; font-size: 0.8rem; font-weight: 500;
      transition: all 0.2s;
    }
    .btn-primary { background: #2F4A34; color: white; }
    .btn-primary:hover { background: #5E7F5E; }
    .btn-danger { background: #c0392b; color: white; }
    .btn-danger:hover { background: #e74c3c; }
    .btn-sm { padding: 5px 10px; font-size: 0.75rem; }
    .btn-success { background: #27ae60; color: white; }
    .btn-warning { background: #f39c12; color: white; }
    form { display: inline; }
    input, select, textarea {
      padding: 8px 12px; border: 2px solid #ddd; border-radius: 6px;
      font-size: 0.85rem; font-family: inherit; transition: border 0.2s;
    }
    input:focus, select:focus { outline: none; border-color: #2F4A34; }
    .form-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 12px; background: white; padding: 20px; border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 20px;
    }
    .form-grid .field { display: flex; flex-direction: column; gap: 4px; }
    .form-grid .field label { font-size: 0.8rem; font-weight: 600; }
    .stats-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 20px; margin-bottom: 30px;
    }
    .stat-card {
      background: white; padding: 24px; border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06); text-align: center;
    }
    .stat-card .num { font-size: 2.2rem; font-weight: 700; color: #2F4A34; }
    .stat-card .label { font-size: 0.8rem; color: #666; margin-top: 4px; }
    .badge {
      display: inline-block; padding: 3px 8px; border-radius: 12px;
      font-size: 0.7rem; font-weight: 600;
    }
    .badge-pendiente { background: #fef3cd; color: #856404; }
    .badge-confirmada { background: #d4edda; color: #155724; }
    .badge-completada { background: #cce5ff; color: #004085; }
    .badge-cancelada { background: #f8d7da; color: #721c24; }
    .badge-true { background: #d4edda; color: #155724; }
    .badge-false { background: #f8d7da; color: #721c24; }
    .empty { text-align: center; padding: 40px; color: #999; }
    .alert { padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 0.85rem; }
    .alert-error { background: #f8d7da; color: #721c24; }
    hr { border: none; border-top: 1px solid #e0d8cc; margin: 24px 0; }
  </style>
</head>
<body>
<% if (user) { %>
<div class="sidebar">
  <h2>🌿 Lush Nails</h2>
  <nav>
    <a href="/" class="<%= path === '/' ? 'active' : '' %>">Dashboard</a>
    <a href="/servicios" class="<%= path.startsWith('/servicios') ? 'active' : '' %>">Servicios</a>
    <a href="/sucursales" class="<%= path.startsWith('/sucursales') ? 'active' : '' %>">Sucursales</a>
    <a href="/citas" class="<%= path.startsWith('/citas') ? 'active' : '' %>">Citas</a>
    <a href="/postulaciones" class="<%= path.startsWith('/postulaciones') ? 'active' : '' %>">Postulaciones</a>
    <a href="/galeria" class="<%= path.startsWith('/galeria') ? 'active' : '' %>">Galería</a>
    <a href="/configuracion" class="<%= path.startsWith('/configuracion') ? 'active' : '' %>">Configuración</a>
  </nav>
  <div class="user-info">
    <%= user.nombre %> (<%= user.rol %>)<br>
    <a href="/logout">Cerrar sesión</a>
  </div>
</div>
<div class="main">
<% } %>
