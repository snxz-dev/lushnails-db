<%- include('partials/header') %>
<div style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#2F4A34">
  <div style="background:white;padding:40px;border-radius:12px;width:360px;box-shadow:0 8px 30px rgba(0,0,0,0.2)">
    <h2 style="text-align:center;margin-bottom:8px;color:#2F4A34">🌿 Lush Nails Spa</h2>
    <p style="text-align:center;font-size:0.85rem;color:#666;margin-bottom:24px">Panel de Administración</p>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <form method="POST">
      <div style="margin-bottom:16px">
        <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:6px">Email</label>
        <input type="email" name="email" required style="width:100%;padding:10px 14px;border:2px solid #ddd;border-radius:6px;font-size:0.9rem">
      </div>
      <div style="margin-bottom:24px">
        <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:6px">Contraseña</label>
        <input type="password" name="password" required style="width:100%;padding:10px 14px;border:2px solid #ddd;border-radius:6px;font-size:0.9rem">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;padding:12px;font-size:0.95rem">Ingresar</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
